<Window x:Class="SpatialScope.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:SpatialScope.Windows.Controls"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="SpatialScope"
        Width="1440"
        Height="920"
        MinWidth="1180"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource InterfaceFont}"
        Foreground="{StaticResource TextBrush}"
        Background="#F4F7F7">
    <Window.Resources>
        <DataTemplate x:Key="ColorEditorTemplate">
            <Button Click="ColorSwatch_Click"
                    Loaded="ColorSwatch_Loaded"
                    Width="54"
                    Height="34"
                    Padding="3"
                    Background="#F8FAFA"
                    BorderBrush="#AAB9BC"
                    BorderThickness="1"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    ToolTip="Choose color">
                <Border CornerRadius="7"
                        BorderBrush="#7D8B8E"
                        BorderThickness="1"
                        Background="{Binding ColorBrush}" />
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="AllPositiveMarkerEditorTemplate">
            <controls:MarkerMultiSelectBox
                AvailableMarkers="{Binding CellTypeMarkerOptions, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectedMarkers="{Binding AllPositive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PickerLabel="{Binding AllPositivePickerLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                Placeholder="{Binding SelectMarkersText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                ClearText="{Binding ClearSelectionText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                PickerHelpText="{Binding MarkerPickerHelpText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectionCountFormat="{Binding MarkerSelectionCountFormat, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectionChanged="CellTypeMarkerSelectionChanged" />
        </DataTemplate>

        <DataTemplate x:Key="AllNegativeMarkerEditorTemplate">
            <controls:MarkerMultiSelectBox
                AvailableMarkers="{Binding CellTypeMarkerOptions, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectedMarkers="{Binding AllNegative, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PickerLabel="{Binding AllNegativePickerLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                Placeholder="{Binding SelectMarkersText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                ClearText="{Binding ClearSelectionText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                PickerHelpText="{Binding MarkerPickerHelpText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectionCountFormat="{Binding MarkerSelectionCountFormat, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectionChanged="CellTypeMarkerSelectionChanged" />
        </DataTemplate>

        <DataTemplate x:Key="AnyPositiveMarkerEditorTemplate">
            <controls:MarkerMultiSelectBox
                AvailableMarkers="{Binding CellTypeMarkerOptions, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectedMarkers="{Binding AnyPositiveGroups, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PickerLabel="{Binding AnyPositivePickerLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                Placeholder="{Binding SelectMarkersText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                ClearText="{Binding ClearSelectionText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                PickerHelpText="{Binding MarkerPickerHelpText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectionCountFormat="{Binding MarkerSelectionCountFormat, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                SelectionChanged="CellTypeMarkerSelectionChanged" />
        </DataTemplate>

        <Style TargetType="ToolTip">
            <Setter Property="FontFamily" Value="{DynamicResource InterfaceFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MaxWidth" Value="460" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F2FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.06" Color="#182126" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource CardTitleTextStyle}" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#006A75" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EFF6F7" />
            <Setter Property="Foreground" Value="#086C77" />
            <Setter Property="BorderBrush" Value="#C8DEE1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="13,9" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SegmentedModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="SegmentBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="#E5F1F3" />
                                <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="#B5D6DA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="#006A75" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="{StaticResource FocusBrush}" />
                                <Setter TargetName="SegmentBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptimizerLockSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track"
                                    Width="42"
                                    Height="24"
                                    HorizontalAlignment="Left"
                                    Background="#BFC9CD"
                                    BorderBrush="#A8B4B8"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Ellipse x:Name="Thumb"
                                         Width="18"
                                         Height="18"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         Fill="White" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="10,0,0,0"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#006A75" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource FocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource FocusBrush}" />
                                <Setter TargetName="Track" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkflowNavigationButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavigationBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavigationBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavigationBorder" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="NavigationBorder" Property="BorderBrush" Value="{StaticResource FocusBrush}" />
                                <Setter TargetName="NavigationBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <!-- Workflow navigation is disabled while an analysis runs,
                                     but semantic status colors must remain fully visible. -->
                                <Setter TargetName="NavigationBorder" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkflowTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    Background="#F0F5F6"
                                    BorderBrush="#CEDCDF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="3"
                                    Margin="0,0,0,16">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Panel.ZIndex="1" />
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkflowTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#E3F0F2" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#B8D5D9" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#006A75" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource FocusBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CDD7DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FAFFFFFF" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CDD7DA" />
            <Setter Property="Background" Value="#FAFFFFFF" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#CDD7DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FAFFFFFF" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E7E9" />
            <Setter Property="BorderBrush" Value="#D6DEE1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#F2F6F7" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#D6DEE1" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7FBFB" Offset="0" />
                <GradientStop Color="#F3FAFB" Offset="0.28" />
                <GradientStop Color="#FBF7FA" Offset="0.69" />
                <GradientStop Color="#F4FAF6" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="330" MaxWidth="380" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F4FFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,22,20,14">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/SpatialScope.png" Width="54" Height="54" Stretch="Uniform" />
                        <StackPanel Margin="13,1,0,0" VerticalAlignment="Center">
                            <TextBlock Text="SpatialScope" FontFamily="{StaticResource DisplayFont}" FontSize="25" FontWeight="Bold" />
                            <TextBlock x:Name="TaglineText" FontSize="13" FontWeight="Medium" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="WorkflowProgressLabel" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="WorkflowProgressText" Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                    </Grid>
                    <ProgressBar x:Name="WorkflowProgressBar" Height="7" Margin="0,7,0,0" Maximum="9" Foreground="{StaticResource AccentBrush}" Background="#DDE5E7" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LanguageLabel" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                        <ComboBox x:Name="LanguageComboBox" Grid.Column="1" SelectionChanged="LanguageComboBox_SelectionChanged">
                            <ComboBoxItem Tag="System" />
                            <ComboBoxItem Tag="English" />
                            <ComboBoxItem Tag="SimplifiedChinese" />
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="WorkflowItemsControl" Margin="12,0,12,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource WorkflowNavigationButtonStyle}"
                                        Background="{Binding StatusBackground}"
                                        BorderBrush="{Binding BorderBrush}"
                                        BorderThickness="{Binding BorderThickness}"
                                        Margin="0,4"
                                        Padding="11,9"
                                        CommandParameter="{Binding Key}"
                                        automation:AutomationProperties.Name="{Binding Title}"
                                        automation:AutomationProperties.HelpText="{Binding StatusDisplayText}"
                                        Click="WorkflowRow_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="18"
                                                   Foreground="{Binding StatusForeground}"
                                                   VerticalAlignment="Top"
                                                   Margin="1,2,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding NumberText}" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="  " />
                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding StatusGlyph}"
                                                   FontFamily="Segoe UI Symbol, Segoe UI"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding StatusForeground}"
                                                   Margin="8,1,0,0"
                                                   VerticalAlignment="Top" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="#DDE4E6" BorderThickness="0,1,0,0" Padding="18,13,18,16">
                    <StackPanel>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="DatasetLabel" Grid.Column="1" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="DatasetValue" Grid.Column="2" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8EF;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="ScaleLabel" Grid.Column="1" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="ScaleValue" Grid.Column="2" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE950;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="ComputeLabel" Grid.Column="1" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="CpuValue"
                                       Grid.Column="2"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       ToolTipService.ShowDuration="30000" />
                        </Grid>
                        <Border BorderBrush="#DDE4E6" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock x:Name="VersionText"
                                           Style="{StaticResource CaptionTextStyle}"
                                           HorizontalAlignment="Center" />
                                <Button x:Name="CheckForUpdatesButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="CheckForUpdatesButton_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#D8E0E2" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="108" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#CFFFFFFF" BorderBrush="#D6DEE1" BorderThickness="0,0,0,1" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="44" Height="44" CornerRadius="8" Background="#E5F2F4" BorderBrush="#C7E0E3" BorderThickness="1" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderIcon" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="21" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock x:Name="HeaderStep" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock x:Name="HeaderTitle" FontFamily="{DynamicResource DisplayFont}" FontSize="25" FontWeight="SemiBold" Margin="0,2,0,0" />
                        <TextBlock x:Name="HeaderSubtitle" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Border x:Name="HeaderStatusBadge" Grid.Column="2" CornerRadius="15" Padding="11,5" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderStatusText" Style="{StaticResource StatusTextStyle}" />
                    </Border>
                </Grid>
            </Border>

            <ContentControl x:Name="DetailHost" Grid.Row="1" />

            <Border Grid.Row="2" Background="#EFFFFFFF" BorderBrush="#D6DEE1" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="OperationProgress" Width="150" Height="6" Maximum="1" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="{StaticResource RunningBrush}" Visibility="Collapsed" />
                    <Border x:Name="StatusSurface"
                            Grid.Column="1"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8,5"
                            Margin="0,-4,12,-4"
                            automation:AutomationProperties.LiveSetting="Polite">
                        <DockPanel LastChildFill="True">
                            <TextBlock x:Name="StatusIcon"
                                       DockPanel.Dock="Left"
                                       Text="&#xE946;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="15"
                                       Width="24"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="StatusText"
                                       Style="{StaticResource SupportingTextStyle}"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Border>
                    <Button x:Name="OpenOutputButton" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Click="OpenOutputButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
