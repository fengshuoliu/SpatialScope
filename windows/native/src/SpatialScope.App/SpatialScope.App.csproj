<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>SpatialScope</AssemblyName>
    <RootNamespace>SpatialScope.Windows</RootNamespace>
    <ApplicationIcon>..\..\..\desktop\assets\SpatialScope.ico</ApplicationIcon>
    <Version>1.2.6</Version>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Authors>SpatialScope</Authors>
    <Product>SpatialScope for Windows</Product>
  </PropertyGroup>

  <ItemGroup>
    <Using Remove="System.Drawing" />
    <Using Remove="System.Windows.Forms" />
    <Resource Include="..\..\..\desktop\assets\SpatialScope.png" Link="Assets\SpatialScope.png" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SpatialScope.Updater\SpatialScope.Updater.csproj" />
  </ItemGroup>

</Project>
